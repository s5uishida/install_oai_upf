+    // Remove FAR
+    session->fars.erase(
+        std::remove_if(
+            session->fars.begin(), session->fars.end(),
+            [far_id](const auto& f) { return f->far_id.far_id == far_id; }),
+        session->fars.end());
+
+    // Update BPF maps
+    session_program_manager_->ModifyPipeline(session);
+
+    Logger::upf_app().info(
+        "Removed FAR %u from session " SEID_FMT, far_id, seid);
