+
+#include "BPFProgram.h"
+#include "logger.hpp"
+
+// Initialize static ID counter starting from 1
+uint32_t BPFProgram::id_counter_ = 1;
+
+//------------------------------------------------------------------------------
+BPFProgram::BPFProgram() : id_(id_counter_) {
+  id_counter_++;
+  Logger::upf_app().info("BPF Program %u created", id_);
+}
