+ */
+
+#ifndef _PFCP_PDR_H
+#define _PFCP_PDR_H
+
+#include "ie/pdr_id.h"
+#include "ie/precedence.h"
+#include "ie/outer_header_removal.h"
+#include "ie/far_id.h"
+#include "ie/urr_id.h"
