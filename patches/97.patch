+//------------------------------------------------------------------------------
+void UPF_XDPProgram::RemoveProgramMap(uint32_t key) {
+  int32_t fd;
+  // Remove only if exists
+  if (teid_session_map_->Lookup(key, &fd) == 0) {
+    teid_session_map_->Remove(key);
+  }
+}
