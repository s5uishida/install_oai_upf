+//------------------------------------------------------------------------------
+// 3GPP TS 29.244 Section 8.2.17 - Remove FAR
+bool SessionManager::RemoveFar(uint64_t seid, uint32_t far_id) {
+  try {
+    std::lock_guard<std::mutex> lock(sessions_mutex_);
+
+    auto session = GetSession(seid);
