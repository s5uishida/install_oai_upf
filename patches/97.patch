+//------------------------------------------------------------------------------
+// 3GPP TS 29.244 Section 8.2.10 - Update FAR
+bool SessionManager::UpdateFar(
+    uint64_t seid, std::shared_ptr<pfcp::pfcp_far> far) {
+  if (!far) {
+    Logger::upf_app().error("UpdateFar: null FAR");
