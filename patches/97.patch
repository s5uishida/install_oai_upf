-            return PASS;
-          } else {
-            bpf_debug("Gate is close for Session %llu. Drop all traffic", seid);
-            return FAILURE;
-          }
-        }
-      }
-      case DROP: {
-        bpf_debug(
-            "DROP: create_outer_header_gtpu_ipv4() fails for session %llu. "
