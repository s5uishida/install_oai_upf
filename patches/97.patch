+//------------------------------------------------------------------------------
+bool pfcp_session::get(
+    const uint32_t urr_id, std::shared_ptr<pfcp::pfcp_urr>& urr) const {
+  for (auto it : urrs) {
+    if (it->urr_id.urr_id == urr_id) {
+      urr = it;
+      return true;
+    }
+  }
+  return false;
+}
