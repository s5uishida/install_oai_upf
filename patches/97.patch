-
-  bpf_debug(
-      "( (sdf_sport_lower, sdf_sport_upper), packet_sport ) : ( (%u, %u), %u "
-      ")",
-      sdf->src_port.lower_bound, sdf->src_port.upper_bound, packet_src_port);
-
-  bpf_debug(
-      "( (sdf_dport_lower, sdf_dport_upper), packet_dport ) : ( (%u, %u), %u "
